{
  "name": "research-compass",
  "private": true,
  "version": "0.1.0",
  "description": "Research Compass — hackathon MVP",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "db:status": "npx supabase status",
    "docker:up": "docker compose up",
    "docker:up:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:lint": "docker compose --profile tools run --rm tools run lint",
    "docker:build:prod": "docker compose -f docker-compose.prod.yml build"
  }
}
